# =============================================================================
# DroneHub — copy to `.env.local` (local) or set in Vercel / Railway dashboards
# =============================================================================

# --- Database (PostgreSQL) — required for Prisma --------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- Auth ---------------------------------------------------------------------
JWT_SECRET="replace-with-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# --- App ----------------------------------------------------------------------
NODE_ENV="development"

# Next.js API runs on this port locally; Vercel/Railway set PORT automatically.
PORT=3000

# --- Redis (optional — feed cache, future realtime) ---------------------------
# REDIS_URL="redis://localhost:6379"

# --- AWS S3 (optional — uploads / avatars) ------------------------------------
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# --- Frontend → API (optional) --------------------------------------------------
# Leave unset when the Next.js app serves `/api/*` on the same origin (typical Vercel).
# Set when the browser must call a separate API host (e.g. API only on Railway):
# NEXT_PUBLIC_API_URL="https://your-api.up.railway.app"

# --- CORS (optional — separate frontend domain calling API) -------------------
# Comma-separated origins allowed to call `/api/*` from the browser.
# Example: CORS_ORIGIN="https://dronehub.vercel.app,http://localhost:3000"
# CORS_ORIGIN=

# --- Legacy / local only (not used when Prisma + JWT are primary) -------------
# MONGODB_URI=
# MONGODB_DB=

# --- Supabase (optional — only if you enable Supabase auth UI) -----------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
